<!-- ======= Header ======= -->
<header id="header" class="fixed-top d-flex align-items-center">
	<div class="container d-flex align-items-center justify-content-between">

		<div class="logo">
			<h2 class="text-light"><a href="/" title="Разработка интернет-приложений"><span>Node.js</span></a></h2>
		</div>

		<nav id="navbar" class="navbar">
			<ul>
				<li><a class="nav-link scrollto active" href="/news/" title="Новости">Новости</a></li>
				<li><a class="nav-link scrollto" href="/" title="Разработка интернет-приложений">Главная</a></li>
				<li><a class="getstarted scrollto" href="tel:89633673184" rel="nofollow">Заказать</a></li>
			</ul>
			<i class="bi bi-list mobile-nav-toggle"></i>
		</nav><!-- .navbar -->

	</div>
</header><!-- End Header -->

<main id="main">

<section class="breadcrumbs">
	<div class="container">

		<div class="d-flex justify-content-between align-items-center">
			<h2>Новость</h2>
			<ol>
				<li><a href="/" title="Разработка интернет-приложений">Главная</a></li>
				<li><a href="/news/" title="Новости">Новости</a></li>
			</ol>
		</div>

	</div>
</section><!-- Breadcrumbs Section -->

	<div class="container pt-3">{{#each news}}
		<div class="card mb-3">
			<img src="/static/uploads/{{this.img}}" class="card-img-top" title="{{this.title}}" alt="{{this.title}}">
		</div>
		<h1 class="mt-2">{{this.title}}</h1>
		<p class="card-text">
		  <small class="text-muted">{{this.date_add}}</small>
		</p>
		<p class="mt-5">{{{this.content}}}</p>
	</div>{{/each}}

</main><!-- End #main -->